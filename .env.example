# Azure DevOps Server URL
# On-prem example: https://your-tfs-server.company.com/tfs/YourCollection
# Cloud example:   https://dev.azure.com/your-organization
AZURE_DEVOPS_ORG_URL=https://your-tfs-server.company.com/tfs/YourCollection

# Azure DevOps Project Name (the project inside your collection)
AZURE_DEVOPS_PROJECT=YourProjectName

# Personal Access Token (PAT)
# How to get: https://<your-tfs-server>/_usersSettings/tokens
# Required scopes: Work Items (read & write), Code (read & write),
#                  Build (read & execute), Wiki (read & write),
#                  Release (read), Test Management (read)
AZURE_DEVOPS_PAT=your_pat_token_here

# Optional: Custom server name displayed in the MCP client.
# Auto-detected from AZURE_DEVOPS_ORG_URL if omitted.
# Examples:
#   https://dev.azure.com/acme               → "acme"
#   https://tfs.example.com/tfs/CompanyOrg   → "CompanyOrg"
# AZURE_DEVOPS_SERVER_NAME=CustomDisplayName

# Optional: Skip SSL validation for self-signed or corporate CA certificates.
# On-prem TFS often needs this. Leave false for cloud / trusted certs.
# AZURE_DEVOPS_SSL_IGNORE=false
